pkgname=python-frida-tools
_pkgname=frida_tools
pkgver=14.8.1
pkgrel=1
pkgdesc='Frida CLI tools.'
groups=('blackarch' 'blackarch-mobile' 'blackarch-binary' 'blackarch-reversing')
arch=('any')
url='https://pypi.org/project/frida-tools/#files'
license=('custom:unknown')
depends=('python' 'python-frida' 'python-colorama' 'python-prompt_toolkit'
         'python-pygments' 'python-websockets' 'libimobiledevice')
makedepends=('python-setuptools')
source=("https://files.pythonhosted.org/packages/source/${_pkgname::1}/$_pkgname/$_pkgname-$pkgver.tar.gz")
sha512sums=('4e11ea85f2d069a50ba2bd28efbace092c8beebe3ac024f8fb0eea316e0a3bfb51566046701f99e893d4b614baa26a0d46077c0eb86fec29e1ebd870cb3ccbd5')

build() {
  cd "$_pkgname-$pkgver"

  python setup.py build
}

package() {

  cd "$_pkgname-$pkgver"

  python setup.py install --root="$pkgdir" --prefix=/usr -O1 --skip-build
}

